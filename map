<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>기사님별 담당 권역 관리 지도</title>
    <style>
        #map { width: 100%; height: 100vh; }
        .infowindow-padding { padding: 10px; font-size: 14px; line-height: 1.6; }
    </style>
    <script type="text/javascript" src="//dapi.kakao.com/v2/maps/sdk.js?appkey=5285fdc7da347f156b1adda9a9faab95"></script>
</head>
<body>

<div id="map"></div>

<script>
// 1. 지도 생성
var mapContainer = document.getElementById('map'), 
    mapOption = { 
        center: new kakao.maps.LatLng(37.42756, 126.9938693), // 기준이 되는 중심 좌표
        level: 8 
    }; 
var map = new kakao.maps.Map(mapContainer, mapOption);
var infowindow = new kakao.maps.InfoWindow({ removable: true });

// 2. 외부 저장된 나만의 권역 GeoJSON 파일 불러오기
fetch('kimyongseok.json')
    .then(response => response.json())
    .then(geojson => {
        // GeoJSON의 'features' 배열을 순회하며 경계선을 그립니다.
        geojson.features.forEach(feature => {
            
            // 2-1. GeoJSON의 좌표 형식을 카카오맵 좌표(LatLng)로 변환
            // GeoJSON은 [경도(Lng), 위도(Lat)] 순서이므로 뒤집어주어야 합니다.
            var coordinates = feature.geometry.coordinates[0];
            var path = coordinates.map(coord => new kakao.maps.LatLng(coord[1], coord[0]));
            
            // 2-2. GeoJSON에 심어둔 커스텀 정보 가져오기
            var properties = feature.properties;

            // 2-3. 다각형(경계선 영역) 객체 생성
            var polygon = new kakao.maps.Polygon({
                path: path,
                strokeWeight: 2,
                strokeColor: '#004c80',
                strokeOpacity: 0.8,
                fillColor: '#1a75ff',
                fillOpacity: 0.3
            });

            // 2-4. 지도에 올리기
            polygon.setMap(map);

            // 2-5. 클릭 시 담당 기사님 정보 팝업 띄우기
            kakao.maps.event.addListener(polygon, 'click', function(mouseEvent) {
                var content = `
                    <div class="infowindow-padding">
                        <strong>📍 권역: ${properties.region_name}</strong><br>
                        👤 담당자: ${properties.manager}<br>
                        📦 당일 물량: ${properties.volume}
                    </div>
                `;
                infowindow.setContent(content);
                infowindow.setPosition(mouseEvent.latLng);
                infowindow.open(map);
            });
        });
    })
    .catch(error => console.error('데이터를 불러오는 중 오류 발생:', error));
</script>
</body>
</html>
